# Copy to .env.local (or .env) and fill in real values. Both are gitignored.
#   cp .env.example .env.local

# Provider API keys are now stored PER USER in the database (encrypted), entered
# on the in-app "API keys" settings page — they are no longer read from the env.
# ANTHROPIC_API_KEY / OPENAI_API_KEY are not used at runtime anymore.

# Encrypts users' stored API keys at rest (AES-256-GCM). Generate with:
#   openssl rand -base64 32
# If unset, a key is derived from SESSION_SECRET (dev/test only — set this in
# production). Back it up alongside data/: losing it makes stored keys
# unrecoverable and users must re-enter them.
APP_ENCRYPTION_KEY=

# Signs session cookies. Generate one with: openssl rand -hex 32
# (required in production — the server refuses to start without it)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional overrides (defaults shown).
# PORT=3000
# HOST=0.0.0.0          # on the VPS, set 127.0.0.1 to keep the app private
# DB_PATH=data/app.db
# AUDIO_DIR=data/audio
