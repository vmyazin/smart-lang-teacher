# Copy to .env.local (or .env) and fill in real values. Both are gitignored.
#   cp .env.example .env.local

# Required — the core record -> diagnose -> lesson -> TTS loop calls these providers.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Signs session cookies. Generate one with: openssl rand -hex 32
# (falls back to an insecure dev value if unset — always set it in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional overrides (defaults shown).
# PORT=3000
# HOST=0.0.0.0          # on the VPS, set 127.0.0.1 to keep the app private
# DB_PATH=data/app.db
# AUDIO_DIR=data/audio
